# Copy this file to ".env" and edit as needed (local dev only).
# For Docker deployments, set these in the root .env instead.

# Set to true to use mock data instead of the real backend API.
VITE_USE_MOCK=false

# Backend API base URL (only needed when running frontend separately from Docker).
VITE_API_BASE=http://localhost:8000

# Password to protect the /students and /teachers pages.
# Leave empty (or remove) to disable protection.
VITE_ADMIN_PASSWORD=
