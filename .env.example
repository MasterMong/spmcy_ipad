# ─── iPad Distribution System — Docker Compose config ─────────────────────────
# Copy this file to ".env" and edit as needed. Docker Compose reads ".env"
# automatically from the project root. All values have sensible defaults, so
# you can run with an empty .env (or no .env at all) for a standard setup.

# Host port the web app is served on.
# Access the app at http://<server-ip>:<PORT>
# Example: PORT=8080  ->  http://localhost:8080
PORT=8080

# Where the SQLite database and uploaded photos are stored on the HOST.
# These become bind-mounted folders so data is easy to back up / transfer.
# Defaults: ./data and ./uploads (relative to the project root)
#DATA_DIR=./data
#UPLOADS_DIR=./uploads

# SQLite connection string (inside the container). Leave as default unless you
# switch to a different engine like PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@db:5432/ipad
DATABASE_URL=sqlite:////app/data/ipad.db

# Directory inside the container where uploaded delivery photos are written.
# Should match the UPLOADS_DIR bind-mount target. Rarely needs changing.
UPLOAD_DIR=/app/uploads

# Comma-separated list of allowed CORS origins for the API.
# Optional — behind nginx the frontend is same-origin, so usually not needed.
# Set this only if you access the backend directly from another origin.
# Example: CORS_ORIGINS=https://ipad.school.ac.th,http://10.0.0.5:8080
#CORS_ORIGINS=

# Password to protect the /students and /teachers pages in the web UI.
# Leave empty (or remove) to disable protection.
#VITE_ADMIN_PASSWORD=secret
